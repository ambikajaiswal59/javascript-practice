A Promise is an object that represents the result of an asynchronous operation which can be resolved or rejected in the future.

Three State - Pending, Resolved (Fulfilled), Rejected

function getData() {
  return new Promise((resolve) => {
    setTimeout(() => {
      resolve("Data loaded");
    }, 1000);
  });
}

async function fetchData() {
  const data = await getData();
  console.log(data);
}

fetchData();
